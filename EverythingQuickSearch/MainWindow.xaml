<ui:FluentWindow x:Class="EverythingQuickSearch.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" 
                 xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
                 xmlns:local="clr-namespace:EverythingQuickSearch"
                 xmlns:prop="clr-namespace:EverythingQuickSearch.Properties"
                 mc:Ignorable="d"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Acrylic"
                 ResizeMode="NoResize"
                 WindowStyle="None"
                 Topmost="True"
                 Background="{DynamicResource ApplicationBackgroundBrush}"
                 ShowInTaskbar="False"
                 ShowActivated="False"
                 Closing="FluentWindow_Closing"
                 PreviewKeyDown="FluentWindow_PreviewKeyDown"
                 PreviewKeyUp="FluentWindow_PreviewKeyUp"
                 Loaded="FluentWindow_Loaded"
                 Title="Everything Quick Search" 
                 Height="450" 
                 Width="800">

    <Window.Resources>

        <Style x:Key="RoundedFilterButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                CornerRadius="16"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedDropDownButtonButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
            <Setter Property="ToolTipService.BetweenShowDelay" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="FileItemTemplate">
            <Border Margin="5,0,14,0" 
                    CornerRadius="5"
                    Padding="5,2,8,2" 
                    BorderThickness="1"
                    MouseLeftButtonDown="FileItemTemplate_MouseLeftButtonDown"
                    MouseEnter="ItemTemplate_MouseEnter"
                    MouseUp="Item_MouseUp"
                    Background="{Binding Background}"
                    MouseLeave="ItemTemplate_MouseLeave"
                    MouseDown="FileItemTemplate_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="0"
                               Height="auto"
                               Margin="-4,3,0,3"
                               Width="4" 
                               Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Fill="{DynamicResource SelectedItemBarBrush}"
                               HorizontalAlignment="Left" 
                               RadiusX="2"
                               RadiusY="2"/>
                    <Image Margin="8,3,3,3"
                           Grid.Column="0"
                           Height="15"
                           VerticalAlignment="Center"
                           Width="15"
                           Source="{Binding Thumbnail}"/>
                    <TextBlock Text="{Binding Name}"
                               Grid.Column="1"
                               Margin="5,0,10,0"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ModificationDate}"
                               Grid.Column="2"
                               TextAlignment="Right"
                               Foreground="{DynamicResource SystemFillColorSolidNeutralBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>
        </DataTemplate>


        <DataTemplate x:Key="AppFileTemplate">
            <Border Margin="6,0,15,3"
                    CornerRadius="8"
                    Padding="4,4,0,4"
                    Background="{Binding Background}"
                    Height="37"
                    MouseEnter="ItemTemplate_MouseEnter"
                    MouseLeave="ItemTemplate_MouseLeave"
                    MouseDown="AppItemTemplate_MouseDown"
                    MouseUp="AppItemTemplate_MouseUp">
                <Grid >
                    <Rectangle Height="auto"
                               Margin="-3,4,0,4"
                               Width="4" 
                               Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Fill="{DynamicResource  SelectedItemBarBrush}"
                               HorizontalAlignment="Left" 
                               RadiusX="2"
                               RadiusY="2"/>
                    <StackPanel Orientation="Horizontal">
                        <Image Margin="8,0,7,0" 
                               Height="28"
                               Width="28" 
                               Source="{Binding Thumbnail}"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="Fant"
                               UseLayoutRounding="True"/>
                        <TextBlock Text="{Binding Name}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>



    <Grid Margin="10,16,10,10" >

        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="15"
                x:Name="SearchBorder"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Margin="23,17,22,0"
                Height="32"
                BorderThickness="1"
                VerticalAlignment="Top">
            <Grid VerticalAlignment="Center"
                  Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image x:Name="SearchIconImage"
                       Grid.Column="0"
                       Height="16"
                       Margin="7,0,0,0"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="Fant"
                       UseLayoutRounding="True"/>

                <ui:TextBox Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                            x:Name="SearchBarTextBox"
                            Grid.Column="1"
                            CaretBrush="{DynamicResource TextFillColorPrimaryBrush}"
                            PlaceholderEnabled="True"
                            Height="30"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            TextChanged="SearchBarTextBox_TextChanged">
                    <ui:TextBox.Style>
                        <Style TargetType="ui:TextBox">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                        </Style>
                    </ui:TextBox.Style>
                </ui:TextBox>
                <Button Content=".*"
                        x:Name="RegexButton"
                        Click="RegexButton_Click"
                        FontWeight="Medium"
                        Grid.Column="2"
                        Style="{StaticResource RoundedFilterButton}"
                        Margin="0,0,-3,0"
                        Height="26"
                        Width="26"
                        Padding="0"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>


        <Grid Grid.Row="1" Height="40" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalAlignment="Stretch"
                          CanContentScroll="True">

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="{x:Static prop:Lang.SearchWindow_CategoryButton_All}"
                        x:Name="AllFilterButton"
                        MouseEnter="FilterButton_MouseEnter"
                        Tag="{x:Static local:Category.All}"
                        Style="{StaticResource RoundedFilterButton}"
                        Background="{DynamicResource AccentTextFillColorTertiaryBrush}"
                        Click="CategoryButton_Click"/>

                    <Button Content="{x:Static prop:Lang.SearchWindow_CategoryButton_Files}"
                        Tag="{x:Static local:Category.File}"
                        x:Name="FilesFilterButton"
                        MouseEnter="FilterButton_MouseEnter"
                        Style="{StaticResource RoundedFilterButton}"
                        Click="CategoryButton_Click"/>

                    <Button Content="{x:Static prop:Lang.SearchWindow_CategoryButton_Folders}"
                        Tag="{x:Static local:Category.Folder}"
                        x:Name="FoldersFilterButton"
                        MouseEnter="FilterButton_MouseEnter"
                        Style="{StaticResource RoundedFilterButton}"
                        Click="CategoryButton_Click"
                        Margin="0,0,4,0"/>

                    <Separator Height="25"/>


                    <Button Content="{x:Static prop:Lang.SearchWindow_CategoryButton_Executables}"
                        x:Name="AppsFilterButton"
                        MouseEnter="FilterButton_MouseEnter"
                        Tag="{x:Static local:Category.Executable}"
                        Style="{StaticResource RoundedFilterButton}"
                        Click="CategoryButton_Click"
                        Margin="4,0,4,0"/>

                    <Button Content="{x:Static prop:Lang.SearchWindow_CategoryButton_Documents}"
                        Tag="{x:Static local:Category.Document}"
                        x:Name="FilterButton"
                        MouseEnter="FilterButton_MouseEnter"
                        Click="CategoryButton_Click"
                        Style="{StaticResource RoundedFilterButton}"/>

                    <Button Content="{x:Static prop:Lang.SearchWindow_CategoryButton_Images}"
                        Tag="{x:Static local:Category.Image}"
                        x:Name="ImagesFilterButton"
                        MouseEnter="FilterButton_MouseEnter"
                        Click="CategoryButton_Click"
                        Style="{StaticResource RoundedFilterButton}"/>

                    <Button Content="{x:Static prop:Lang.SearchWindow_CategoryButton_Videos}"
                        Tag="{x:Static local:Category.Video}"
                        x:Name="VideoFilterButton"
                        MouseEnter="FilterButton_MouseEnter"
                        Click="CategoryButton_Click"
                        Style="{StaticResource RoundedFilterButton}"/>

                    <Button Content="{x:Static prop:Lang.SearchWindow_CategoryButton_Compressed}"
                        Tag="{x:Static local:Category.Compressed}"
                        x:Name="CompressedFilterButton"
                        MouseEnter="FilterButton_MouseEnter"
                        Click="CategoryButton_Click"
                        Style="{StaticResource RoundedFilterButton}"/>

                </StackPanel>
            </ScrollViewer>
            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <ui:DropDownButton Style="{StaticResource RoundedDropDownButtonButton}"
                                   MouseEnter="RoundedDropDownButtonButton_MouseEnter"
                                   MouseLeave="RoundedDropDownButtonButton_MouseLeave"
                                   BorderThickness="0"
                                   HorizontalAlignment="Right">

                    <ui:DropDownButton.Flyout>
                        <ContextMenu x:Name="SortByContextMenu"/>
                    </ui:DropDownButton.Flyout>

                    <ui:SymbolIcon Symbol="ArrowSort20" 
                                   FontSize="18"/>
                </ui:DropDownButton>
               
                <ui:DropDownButton Style="{StaticResource RoundedDropDownButtonButton}"
                                   MouseEnter="RoundedDropDownButtonButton_MouseEnter"
                                   MouseLeave="RoundedDropDownButtonButton_MouseLeave"
                                   BorderThickness="0"
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Right">

                    <ui:DropDownButton.Flyout>
                        <ContextMenu x:Name="SortByContextMenu3"/>
                    </ui:DropDownButton.Flyout>

                    <ui:SymbolIcon Symbol="Settings20"
                                   FontSize="18"/>
                </ui:DropDownButton>
            </StackPanel>

        </Grid>


        <Grid Grid.Row="2" Margin="0,0,0,0" 
              KeyboardNavigation.TabNavigation="None">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70*"/>
                <ColumnDefinition Width="45*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" KeyboardNavigation.TabNavigation="None">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <ui:DynamicScrollViewer Grid.Row="0" 
                                        Focusable="False" 
                                        x:Name="App_ScrollViewer" 
                                        IsTabStop="False" 
                                        VerticalScrollBarVisibility="Auto">

                    <ItemsControl x:Name="AppItems_ItemsControl"
                                  ItemsSource="{Binding AppItems}" 
                                  ItemTemplate="{StaticResource AppFileTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                </ui:DynamicScrollViewer>


                <Separator Grid.Row="1"
                           x:Name="App_ScrollViewer_Separator" 
                           HorizontalAlignment="Center"
                           Height="7"
                           Margin="10,3,20,3"
                           Width="400"/>
                <Grid Grid.Row="2" 
                      Visibility="Collapsed"
                      x:Name="NoSearchResultsGrid"
                      Margin="10,3,20,3">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon x:Name="NoSearchResultsIcon"
                                       Symbol="Search24"
                                       FontSize="32"
                                       VerticalAlignment="Top"/>
                        <TextBlock FontSize="16"
                                   Margin="10,5"
                                   x:Name="NoSearchResultsTextBlock"/>
                    </StackPanel>
                </Grid>
                <ui:DynamicScrollViewer Grid.Row="2" 
                                        Focusable="False" 
                                        x:Name="scrollViewer" 
                                        ScrollChanged="scrollViewer_ScrollChanged"
                                        CanContentScroll="False"
                                        IsTabStop="False" 
                                        VerticalScrollBarVisibility="Auto">

                    <ItemsControl x:Name="FileItems_ItemsControl"
                                  ItemsSource="{Binding FileItems}"
                                  
                                  ItemTemplate="{StaticResource FileItemTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ui:DynamicScrollViewer>

            </Grid>

            <Border Grid.Column="1"
                    CornerRadius="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    ClipToBounds="True">
                <Border.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="Black"
                                    SnapsToDevicePixels="True"
                                    CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=Border}}"
                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Border}}"
                                    Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Border}}"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Border.OpacityMask>
                <ui:DynamicScrollViewer VerticalScrollBarVisibility="Auto" x:Name="FileDetails_DynamicScrollViewer">
                    <Grid >
                        <StackPanel Orientation="Vertical">

                            <StackPanel HorizontalAlignment="Center" 
                                        VerticalAlignment="Top"
                                        Margin="00,28,0,0"
                                        Width="400">

                                <Border CornerRadius="8"
                                    ClipToBounds="True">
                                    <ui:Image x:Name="SelectedItemPreviewImage"
                                       Cursor="Hand"
                                       MouseDown="SelectedItemPreviewImage_MouseDown"
                                       MouseUp="Item_MouseUp"
                                       Height="250" 
                                       Width="64"
                                       CornerRadius="6"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="Fant"
                                       UseLayoutRounding="True">
                                    </ui:Image>
                                </Border>

                                <TextBlock x:Name="SelectedItemPreviewName"
                                           HorizontalAlignment="Center" 
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Width="200"
                                           Text=""
                                           MaxHeight="70"
                                           Padding="0,10,0,0"
                                           FontSize="16"/>

                                <Separator Width="280"
                                           HorizontalAlignment="Center"
                                           Margin="0,6" />

                            </StackPanel>


                            <Grid x:Name="FilePreviewGrid"
                                  Visibility="Collapsed"
                                  Margin="20,0">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"                                          
                                           Text="{x:Static prop:Lang.SearchWindow_Item_Details_Location}"/>

                                <TextBlock x:Name="FilePreviewMPath"
                                           
                                           Grid.Column="1"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Padding="0,10,20,0"
                                           FontSize="12"
                                           Text="{x:Static prop:Lang.SearchWindow_Item_Details_LastModified}"/>

                                <TextBlock x:Name="FilePreviewModDate"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Padding="0,10,0,0"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>

                                <TextBlock x:Name="FilePreviewResolutionTextBlock"
                                           Grid.Row="2"
                                           Grid.Column="0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Padding="0,10,20,0"
                                           FontSize="12"
                                           Text="{x:Static prop:Lang.SearchWindow_Item_Details_Resolution}"/>

                                <TextBlock x:Name="FilePreviewResolution"
                                           Grid.Row="2"
                                           Grid.Column="1"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Padding="0,10,0,0"
                                           Text="x by y"
                                           FontSize="12"/>


                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Padding="0,10,20,0"
                                           FontSize="12"
                                           Text="{x:Static prop:Lang.SearchWindow_Item_Details_Size}"/>

                                <TextBlock x:Name="FilePreviewSize"
                                           Grid.Row="3"
                                           Grid.Column="1"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Padding="0,10,0,0"
                                           FontSize="12"/>
                            </Grid>

                            <Separator x:Name="ActionSeparator"
                                   Width="280"
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   Margin="0,6" />

                            <Border x:Name="OpenFileBorder"
                                MouseDown="OpenFileBorder_MouseDown"
                                CornerRadius="5"
                                MouseEnter="Border_MouseEnter"
                                MouseLeave="Border_MouseLeave"
                                Background="Transparent"
                                Height="30"  
                                Margin="10,0,10,5">
                                <StackPanel 
                                    Orientation="Horizontal"
                                    Margin="5,0" 
                                    VerticalAlignment="Center">

                                    <ui:SymbolIcon 
                                        Symbol="Open16"
                                        Margin="3,0,0,0"
                                        FontSize="16" 
                                        VerticalAlignment="Center"/>

                                    <TextBlock Text="{x:Static prop:Lang.SearchWindow_Item_Actions_OpenFile}"
                                               Margin="8,0" 
                                               FontSize="13" 
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="RunasAdminBorder"
                                    CornerRadius="5"
                                    Height="30"  
                                    MouseEnter="Border_MouseEnter"
                                    MouseLeave="Border_MouseLeave"
                                    MouseDown="RunasAdminBorder_MouseDown"
                                    Background="Transparent"
                                    Margin="10,0,10,5">
                                <StackPanel x:Name="RunasAdmin"
                                            Orientation="Horizontal"
                                            Margin="5,0"
                                            VerticalAlignment="Center">

                                    <ui:SymbolIcon Symbol="CalendarShield16"
                                                   Margin="3,0,0,0"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>

                                    <TextBlock Text="{x:Static prop:Lang.SearchWindow_Item_Actions_RunAsAdministrator}"
                                               Margin="8,0"
                                               FontSize="13" 
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="OpenFileLocationBorder"
                                    MouseDown="OpenFileLocationBorder_MouseDown"
                                    CornerRadius="5"
                                    Height="30"  
                                    MouseEnter="Border_MouseEnter"
                                    MouseLeave="Border_MouseLeave"
                                    Background="Transparent"
                                   Margin="10,0">
                                <StackPanel Orientation="Horizontal"
                                            Margin="5,0"
                                            VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="FolderOpen16"
                                                   Margin="3,0,0,0"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Static prop:Lang.SearchWindow_Item_Actions_OpenFileLocation}"
                                               Margin="8,0"
                                               FontSize="13" 
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </ui:DynamicScrollViewer>
            </Border>
        </Grid>
        <tray:NotifyIcon Grid.Row="0" 
                         Icon="/Icon/icon2.ico"
                         FocusOnLeftClick="True"  
                         Name="TrayIcon"
                         MenuOnRightClick="True"
                         TooltipText="Everything Quick Search" >
            <tray:NotifyIcon.Menu>
                <ContextMenu MinWidth="65">
                    <MenuItem Name="versionHeader"
                              Header="{x:Static prop:Lang.TrayIcon_Version}"
                              FontSize="10"
                              IsEnabled="False"
                              HorizontalAlignment="Center"
                              Background="{x:Null}"
                              FontFamily="Segoe Print"/>

                    <ui:MenuItem x:Name="Update_Button"
                           Header="{x:Static prop:Lang.TrayIcon_CheckForUpdate}"
                           Click="Update_Button_Click" 
                           Icon="{ui:SymbolIcon Symbol=ArrowSync20}"/>
                    <ui:MenuItem x:Name="visitGithub_Buton" 
                           Header="{x:Static prop:Lang.TrayIcon_VisitGitHub}"
                           Click="visitGithub_Buton_Click"
                           Icon="{ui:SymbolIcon Symbol=Link20}"/>
                    <Separator Margin="0,3,0,3"/>

                    <ui:ToggleSwitch x:Name="AutoUpdateToggle" 
                                     Content="{x:Static prop:Lang.TrayIcon_AutoUpdate}"
                                     Checked="AutoUpdateToggle_CheckChanged" 
                                     Unchecked="AutoUpdateToggle_CheckChanged"/>

                    <ui:ToggleSwitch x:Name="AutorunToggle" 
                               Content="{x:Static prop:Lang.TrayIcon_StartOnLogin}"
                               Checked="AutorunToggle_CheckChanged" 
                               Unchecked="AutorunToggle_CheckChanged"/>

                    <Separator Margin="0,3,0,3"/>

                    <MenuItem x:Name="Exit_Button" Height="34" 
                        Header="{x:Static prop:Lang.TrayIcon_Exit}" Click="ExitApp"
                        Icon="{ui:SymbolIcon Symbol=ArrowExit20}" />

                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</ui:FluentWindow>